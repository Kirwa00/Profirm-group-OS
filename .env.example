# Required to disable Next.js telemetry on this OneDrive-synced path
# (avoids an EXDEV cross-device-link crash when telemetry tries to write its config)
NEXT_TELEMETRY_DISABLED=1

# Hosted Postgres connection string (Supabase, Neon, etc). The app boots and
# renders setup banners without this — add it, then run:
#   npm run db:push && npm run db:seed
DATABASE_URL=

# NextAuth v5 secret — generate with: npx auth secret
AUTH_SECRET=

# Optional: override the seeded admin credentials (defaults shown)
SEED_ADMIN_EMAIL=admin@profirmgroup.com
SEED_ADMIN_PASSWORD=ProfirmOS2026!
